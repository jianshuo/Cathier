# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane
default_platform(:ios)

  platform :ios do

    desc "Build and upload to TestFlight"
    lane :beta do
      setup_ci  # configures keychain in CI environment

      # Create API key once and reuse for all steps
      # ASC_API_KEY_CONTENT must be stored as base64 in GitHub Secrets:
      #   base64 -i AuthKey_XXXX.p8 | tr -d '\n' | pbcopy
      api_key = app_store_connect_api_key(
        key_id:                ENV["ASC_API_KEY_ID"],
        issuer_id:             ENV["ASC_API_ISSUER_ID"],
        key_content:           ENV["ASC_API_KEY_CONTENT"],
        is_key_content_base64: true,
        duration:              1200,
        in_house:              false
      )

      # Code signing via Match
      match(
        type: "appstore",
        readonly: true,
        git_basic_authorization: Base64.strict_encode64(ENV["MATCH_GIT_BASIC_AUTH"]),
        api_key: api_key
      )

      # Increment build number automatically
      # RUN_NUMBER * 10 + RUN_ATTEMPT ensures re-runs also get a unique, increasing number
      increment_build_number(
        build_number: ENV["GITHUB_RUN_NUMBER"].to_i * 10 + (ENV["GITHUB_RUN_ATTEMPT"] || "1").to_i
      )

      # Build
      build_app(
        scheme: "Cathier",
        export_method: "app-store",
        xcargs: "CODE_SIGN_STYLE=Manual CODE_SIGN_IDENTITY='Apple Distribution' PROVISIONING_PROFILE_SPECIFIER='match AppStore com.wangjianshuo.cathier.Cathier'",
        export_options: {
          provisioningProfiles: {
            "com.wangjianshuo.cathier.Cathier" => "match AppStore com.wangjianshuo.cathier.Cathier"
          }
        }
      )

      # Upload to TestFlight and auto-distribute to internal testers
      upload_to_testflight(
        api_key: api_key,
        skip_waiting_for_build_processing: false,
        distribute_external:               false,
        notify_external_testers:           false,
        changelog:                         "Build #{ENV['GITHUB_RUN_NUMBER']} — auto-deployed from main"
      )
    end

    desc "Build, upload to TestFlight, and submit for App Store review"
    lane :release do
      setup_ci

      api_key = app_store_connect_api_key(
        key_id:                ENV["ASC_API_KEY_ID"],
        issuer_id:             ENV["ASC_API_ISSUER_ID"],
        key_content:           ENV["ASC_API_KEY_CONTENT"],
        is_key_content_base64: true,
        duration:              1200,
        in_house:              false
      )

      match(
        type: "appstore",
        readonly: true,
        git_basic_authorization: Base64.strict_encode64(ENV["MATCH_GIT_BASIC_AUTH"]),
        api_key: api_key
      )

      increment_build_number(
        build_number: ENV["GITHUB_RUN_NUMBER"].to_i * 10 + (ENV["GITHUB_RUN_ATTEMPT"] || "1").to_i
      )

      build_app(
        scheme: "Cathier",
        export_method: "app-store",
        xcargs: "CODE_SIGN_STYLE=Manual CODE_SIGN_IDENTITY='Apple Distribution' PROVISIONING_PROFILE_SPECIFIER='match AppStore com.wangjianshuo.cathier.Cathier'",
        export_options: {
          provisioningProfiles: {
            "com.wangjianshuo.cathier.Cathier" => "match AppStore com.wangjianshuo.cathier.Cathier"
          }
        }
      )

      # Upload and submit for App Store review
      upload_to_app_store(
        api_key:                             api_key,
        skip_metadata:                       true,
        skip_screenshots:                    true,
        submit_for_review:                   true,
        automatic_release:                   false,
        submission_information: {
          add_id_info_uses_idfa:             false,
          export_compliance_uses_encryption: false,
        }
      )
    end

  end
